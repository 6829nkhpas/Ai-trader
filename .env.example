# ── Kite Connect API ────────────────────────────────────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:3000/api/auth/kite

# Set KITE_ACCESS_TOKEN directly if you already have a valid token (resets at midnight IST).
# Otherwise set KITE_REQUEST_TOKEN (from OAuth redirect) and the service will exchange it.
KITE_ACCESS_TOKEN=
KITE_REQUEST_TOKEN=

# Comma-separated list of instrument_token:SYMBOL pairs to subscribe to
# Tokens can be found via: https://api.kite.trade/instruments/NSE
KITE_INSTRUMENT_TOKENS=738561:RELIANCE,260105:BANKNIFTY,256265:NIFTY 50

# ── External Data APIs ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=s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
