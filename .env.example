# ── Docker Infrastructure ───────────────────────────────────────────────────
# Kafka — ingestion service reads KAFKA_BROKER_URL (falls back to KAFKA_BROKERS)
KAFKA_BROKER_URL=localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_BROKERS_INTERNAL=broker:29092

# QuestDB
QUESTDB_POSTGRES_URL=postgresql://admin:quest@questdb:8812/qdb
QUESTDB_ILP_ADDR=127.0.0.1:9009
QUESTDB_ILP_ADDR_INTERNAL=questdb:9009

# Redis
REDIS_URL=redis://redis:6379

# WebSocket gateway port (frontend ↔ aggregator)
WEBSOCKET_PORT=8080
